    <sql id="selectBasicStockVo">
        select basic_stock_id, serial_no, stock_code, stock_name, latest_price, change_percent, price_rise_fall, volume, turnover, amplitude, highest_price, lowest_price, today_open_price, yesterday_closing_price, volume_ratio, turnover_rate, dynamic_price_ratio, price_to_book_ratio, listing_time, total_market_value, circulating_market_value, growth_rate, mins5_change_percent, days60_change_percent, year_change_percent, stock_market_type, biz_date, created_by, created_date, updated_by, updated_date from basic_stock
    </sql>

    <select id="selectBasicStockList" parameterType="BasicStock" resultMap="BasicStockResult">
        <include refid="selectBasicStockVo"/>
        <where>  
            <if test="serialNo != null "> and serial_no = #{serialNo}</if>
            <if test="stockCode != null  and stockCode != ''"> and stock_code = #{stockCode}</if>
            <if test="stockName != null  and stockName != ''"> and stock_name like concat('%', #{stockName}, '%')</if>
            <if test="latestPrice != null  and latestPrice != ''"> and latest_price = #{latestPrice}</if>
            <if test="changePercent != null  and changePercent != ''"> and change_percent = #{changePercent}</if>
            <if test="priceRiseFall != null  and priceRiseFall != ''"> and price_rise_fall = #{priceRiseFall}</if>
            <if test="volume != null  and volume != ''"> and volume = #{volume}</if>
            <if test="turnover != null "> and turnover = #{turnover}</if>
            <if test="amplitude != null  and amplitude != ''"> and amplitude = #{amplitude}</if>
            <if test="highestPrice != null  and highestPrice != ''"> and highest_price = #{highestPrice}</if>
            <if test="lowestPrice != null  and lowestPrice != ''"> and lowest_price = #{lowestPrice}</if>
            <if test="todayOpenPrice != null  and todayOpenPrice != ''"> and today_open_price = #{todayOpenPrice}</if>
            <if test="yesterdayClosingPrice != null  and yesterdayClosingPrice != ''"> and yesterday_closing_price = #{yesterdayClosingPrice}</if>
