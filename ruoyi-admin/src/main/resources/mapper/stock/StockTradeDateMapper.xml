<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.stock.mapper.StockTradeDateMapper">
    
    <resultMap type="StockTradeDate" id="StockTradeDateResult">
        <result property="tradeDateId"    column="trade_date_id"    />
        <result property="tradeDate"    column="trade_date"    />
        <result property="createdBy"    column="created_by"    />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedBy"    column="updated_by"    />
        <result property="updatedDate"    column="updated_date"    />
    </resultMap>

    <sql id="selectStockTradeDateVo">
        select trade_date_id, trade_date, created_by, created_date, updated_by, updated_date from stock_trade_date
    </sql>

    <select id="selectStockTradeDateList" parameterType="StockTradeDate" resultMap="StockTradeDateResult">
        <include refid="selectStockTradeDateVo"/>
        <where>  
            <if test="tradeDate != null  and tradeDate != ''"> and trade_date = #{tradeDate}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
        </where>
    </select>
    
    <select id="selectStockTradeDateByTradeDateId" parameterType="Long" resultMap="StockTradeDateResult">
        <include refid="selectStockTradeDateVo"/>
        where trade_date_id = #{tradeDateId}
    </select>
        
    <insert id="insertStockTradeDate" parameterType="StockTradeDate" useGeneratedKeys="true" keyProperty="tradeDateId">
        insert into stock_trade_date
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tradeDate != null and tradeDate != ''">trade_date,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="updatedDate != null">updated_date,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tradeDate != null and tradeDate != ''">#{tradeDate},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
         </trim>
    </insert>

    <update id="updateStockTradeDate" parameterType="StockTradeDate">
        update stock_trade_date
        <trim prefix="SET" suffixOverrides=",">
            <if test="tradeDate != null and tradeDate != ''">trade_date = #{tradeDate},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
        </trim>
        where trade_date_id = #{tradeDateId}
    </update>

    <delete id="deleteStockTradeDateByTradeDateId" parameterType="Long">
        delete from stock_trade_date where trade_date_id = #{tradeDateId}
    </delete>

    <delete id="deleteStockTradeDateByTradeDateIds" parameterType="String">
        delete from stock_trade_date where trade_date_id in 
        <foreach item="tradeDateId" collection="array" open="(" separator="," close=")">
            #{tradeDateId}
        </foreach>
    </delete>
</mapper>