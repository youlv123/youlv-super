<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.stock.mapper.ThsStockFundFlowMapper">

    <resultMap type="ThsStockFundFlow" id="ThsStockFundFlowResult">
        <result property="fundFlowIndividualId"    column="fund_flow_individual_id"    />
        <result property="serialNo"    column="serial_no"    />
        <result property="stockCode"    column="stock_code"    />
        <result property="stockName"    column="stock_name"    />
        <result property="latestPrice"    column="latest_price"    />
        <result property="changePercent"    column="change_percent"    />
        <result property="turnoverRate"    column="turnover_rate"    />
        <result property="inflowFunds"    column="inflow_funds"    />
        <result property="outflowFunds"    column="outflow_funds"    />
        <result property="netAmount"    column="net_amount"    />
        <result property="turnover"    column="turnover"    />
        <result property="type"    column="type"    />
        <result property="createdBy"    column="created_by"    />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedBy"    column="updated_by"    />
        <result property="updatedDate"    column="updated_date"    />
    </resultMap>

    <sql id="selectThsStockFundFlowVo">
        select fund_flow_individual_id, serial_no, stock_code, stock_name, latest_price, change_percent, turnover_rate, inflow_funds, outflow_funds, net_amount, turnover, type, created_by, created_date, updated_by, updated_date from ths_stock_fund_flow
    </sql>

    <select id="selectThsStockFundFlowList" parameterType="ThsStockFundFlow" resultMap="ThsStockFundFlowResult">
        <include refid="selectThsStockFundFlowVo"/>
        <where>
            <if test="serialNo != null "> and serial_no = #{serialNo}</if>
            <if test="stockCode != null  and stockCode != ''"> and stock_code = #{stockCode}</if>
            <if test="stockName != null  and stockName != ''"> and stock_name like concat('%', #{stockName}, '%')</if>
            <if test="latestPrice != null "> and latest_price = #{latestPrice}</if>
            <if test="changePercent != null "> and change_percent = #{changePercent}</if>
            <if test="turnoverRate != null "> and turnover_rate = #{turnoverRate}</if>
            <if test="inflowFunds != null "> and inflow_funds = #{inflowFunds}</if>
            <if test="outflowFunds != null "> and outflow_funds = #{outflowFunds}</if>
            <if test="netAmount != null "> and net_amount = #{netAmount}</if>
            <if test="turnover != null "> and turnover = #{turnover}</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
        </where>
    </select>

    <select id="selectThsStockFundFlowByFundFlowIndividualId" parameterType="Long" resultMap="ThsStockFundFlowResult">
        <include refid="selectThsStockFundFlowVo"/>
        where fund_flow_individual_id = #{fundFlowIndividualId}
    </select>

    <insert id="insertThsStockFundFlow" parameterType="ThsStockFundFlow" useGeneratedKeys="true" keyProperty="fundFlowIndividualId">
        insert into ths_stock_fund_flow
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="serialNo != null">serial_no,</if>
            <if test="stockCode != null and stockCode != ''">stock_code,</if>
            <if test="stockName != null and stockName != ''">stock_name,</if>
            <if test="latestPrice != null">latest_price,</if>
            <if test="changePercent != null">change_percent,</if>
            <if test="turnoverRate != null">turnover_rate,</if>
            <if test="inflowFunds != null">inflow_funds,</if>
            <if test="outflowFunds != null">outflow_funds,</if>
            <if test="netAmount != null">net_amount,</if>
            <if test="turnover != null">turnover,</if>
            <if test="type != null">type,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="updatedDate != null">updated_date,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="serialNo != null">#{serialNo},</if>
            <if test="stockCode != null and stockCode != ''">#{stockCode},</if>
            <if test="stockName != null and stockName != ''">#{stockName},</if>
            <if test="latestPrice != null">#{latestPrice},</if>
            <if test="changePercent != null">#{changePercent},</if>
            <if test="turnoverRate != null">#{turnoverRate},</if>
            <if test="inflowFunds != null">#{inflowFunds},</if>
            <if test="outflowFunds != null">#{outflowFunds},</if>
            <if test="netAmount != null">#{netAmount},</if>
            <if test="turnover != null">#{turnover},</if>
            <if test="type != null">#{type},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
         </trim>
    </insert>

    <update id="updateThsStockFundFlow" parameterType="ThsStockFundFlow">
        update ths_stock_fund_flow
        <trim prefix="SET" suffixOverrides=",">
            <if test="serialNo != null">serial_no = #{serialNo},</if>
            <if test="stockCode != null and stockCode != ''">stock_code = #{stockCode},</if>
            <if test="stockName != null and stockName != ''">stock_name = #{stockName},</if>
            <if test="latestPrice != null">latest_price = #{latestPrice},</if>
            <if test="changePercent != null">change_percent = #{changePercent},</if>
            <if test="turnoverRate != null">turnover_rate = #{turnoverRate},</if>
            <if test="inflowFunds != null">inflow_funds = #{inflowFunds},</if>
            <if test="outflowFunds != null">outflow_funds = #{outflowFunds},</if>
            <if test="netAmount != null">net_amount = #{netAmount},</if>
            <if test="turnover != null">turnover = #{turnover},</if>
            <if test="type != null">type = #{type},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
        </trim>
        where fund_flow_individual_id = #{fundFlowIndividualId}
    </update>

    <delete id="deleteThsStockFundFlowByFundFlowIndividualId" parameterType="Long">
        delete from ths_stock_fund_flow where fund_flow_individual_id = #{fundFlowIndividualId}
    </delete>

    <delete id="deleteThsStockFundFlowByFundFlowIndividualIds" parameterType="String">
        delete from ths_stock_fund_flow where fund_flow_individual_id in
        <foreach item="fundFlowIndividualId" collection="array" open="(" separator="," close=")">
            #{fundFlowIndividualId}
        </foreach>
    </delete>

    <delete id="truncateThsStockFundFlow">
        truncate table ths_stock_fund_flow
    </delete>
</mapper>
