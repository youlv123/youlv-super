<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ItemCategoryRelationMapper">

    <resultMap type="ItemCategoryRelationDTO" id="ItemCategoryRelationResult">
        <result property="relationId" column="relation_id"/>
        <result property="itemId" column="item_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdDate" column="created_date"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="updatedDate" column="updated_date"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectItemCategoryRelationVo">
        select relation_id,
               item_id,
               category_id,
               user_id,
               user_name,
               created_by,
               created_date,
               updated_by,
               updated_date,
               del_flag
        from item_category_relation
    </sql>

    <select id="selectItemCategoryRelationList" parameterType="ItemCategoryRelationDTO"
            resultMap="ItemCategoryRelationResult">
        <include refid="selectItemCategoryRelationVo"/>
        <where>
            <if test="itemId != null ">and item_id = #{itemId}</if>
            <if test="categoryId != null ">and category_id = #{categoryId}</if>
            <if test="userId != null ">and user_id = #{userId}</if>
            <if test="userName != null  and userName != ''">and user_name like concat('%', #{userName}, '%')</if>
            <if test="createdBy != null  and createdBy != ''">and created_by like concat('%', #{createdBy}, '%')</if>
            <if test="params.beginCreatedDate != null and params.beginCreatedDate != '' and params.endCreatedDate != null and params.endCreatedDate != ''">
                and created_date between #{params.beginCreatedDate} and #{params.endCreatedDate}
            </if>
            <if test="updatedBy != null  and updatedBy != ''">and updated_by like concat('%', #{updatedBy}, '%')</if>
            <if test="params.beginUpdatedDate != null and params.beginUpdatedDate != '' and params.endUpdatedDate != null and params.endUpdatedDate != ''">
                and updated_date between #{params.beginUpdatedDate} and #{params.endUpdatedDate}
            </if>
            <if test="delFlag != null">and del_flag=#{delFlag}</if>
        </where>
    </select>

    <select id="selectItemCategoryRelationByRelationId" parameterType="Long" resultMap="ItemCategoryRelationResult">
        <include refid="selectItemCategoryRelationVo"/>
        where relation_id = #{relationId}
    </select>

    <insert id="insertItemCategoryRelation" parameterType="ItemCategoryRelationDTO" useGeneratedKeys="true"
            keyProperty="relationId">
        insert into item_category_relation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemId != null">item_id,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="updatedDate != null">updated_date,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemId != null">#{itemId},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateItemCategoryRelation" parameterType="ItemCategoryRelationDTO">
        update item_category_relation
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemId != null">item_id = #{itemId},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where relation_id = #{relationId}
    </update>

    <delete id="deleteItemCategoryRelationByRelationId" parameterType="Long">
        delete
        from item_category_relation
        where relation_id = #{relationId}
    </delete>

    <delete id="deleteItemCategoryRelationByRelationIds" parameterType="String">
        delete from item_category_relation where relation_id in
        <foreach item="relationId" collection="array" open="(" separator="," close=")">
            #{relationId}
        </foreach>
    </delete>

    <delete id="updateItemCategoryRelationByitemIds" parameterType="String">
        update item_category_relation  set del_flag='1' where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>


    <delete id="deleteItemCategoryRelationByitemIds" parameterType="String">
        delete from item_category_relation where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <insert id="batchInsertItemCategoryRelation" parameterType="java.util.List">
        insert into item_category_relation (item_id, category_id, user_id, user_name, created_by, created_date,
        updated_by, updated_date, del_flag)
        values
        <foreach collection="list" item="item" separator=",">
            (
            <if test="item.itemId != null">#{item.itemId},</if>
            <if test="item.categoryId != null">#{item.categoryId},</if>
            <if test="item.userId != null">#{item.userId},</if>
            <if test="item.userName != null">#{item.userName},</if>
            <if test="item.createdBy != null">#{item.createdBy},</if>
            <if test="item.createdDate != null">#{item.createdDate},</if>
            <if test="item.updatedBy != null">#{item.updatedBy},</if>
            <if test="item.updatedDate != null">#{item.updatedDate},</if>
            <if test="item.delFlag != null">#{item.delFlag}</if>
            )
        </foreach>
    </insert>

    <update id="deleteItemInformationByItemCategoryId" parameterType="ItemCategoryRelationDTO">
        update item_category_relation
        SET del_flag     = #{delFlag},
            updated_by   = #{updatedBy},
            updated_date = #{updatedDate}
        where
           item_id = #{itemId}
          and user_id = #{userId}
        <if test="categoryId != null ">and category_id = #{categoryId}</if>
    </update>

    <select id="selectCountBycategoryId" parameterType="Long" resultType="java.lang.Long">
        select count(1)
        from item_category_relation
        where category_id = #{categoryId} and del_flag='0'
    </select>
</mapper>
