<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.WorkTimeRecordMapper">

    <resultMap type="WorkTimeRecordDTO" id="WorkTimeRecordResult">
        <result property="recordId"    column="record_id"    />
        <result property="belongsProjects"    column="belongs_projects"    />
        <result property="todayDate"    column="today_date"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="totalMinutesDuration"    column="total_minutes_duration"    />
        <result property="totalHoursDuration"    column="total_hours_duration"    />
        <result property="workContent"    column="work_content"    />
        <result property="createdBy"    column="created_by"  />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedBy"    column="updated_by" />
        <result property="updatedDate"    column="updated_date"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectWorkTimeRecordVo">
        select record_id, belongs_projects, today_date, start_time, end_time, total_minutes_duration, total_hours_duration, work_content, created_by, created_date, updated_by, updated_date, del_flag from work_time_record
    </sql>

    <select id="selectWorkTimeRecordList" parameterType="WorkTimeRecordDTO" resultMap="WorkTimeRecordResult">
        <include refid="selectWorkTimeRecordVo"/>
        <where>
            <if test="belongsProjects != null  and belongsProjects != ''"> and belongs_projects = #{belongsProjects}</if>
            <if test="todayDate != null  and todayDate != ''"> and today_date = #{todayDate}</if>
            <if test="params.beginStartTime != null and params.beginStartTime != '' and params.endStartTime != null and params.endStartTime != ''"> and start_time between #{params.beginStartTime} and #{params.endStartTime}</if>
            <if test="params.beginEndTime != null and params.beginEndTime != '' and params.endEndTime != null and params.endEndTime != ''"> and end_time between #{params.beginEndTime} and #{params.endEndTime}</if>
            <if test="params.beginTotalMinutesDuration != null and params.beginTotalMinutesDuration != '' and params.endTotalMinutesDuration != null and params.endTotalMinutesDuration != ''"> and total_minutes_duration between #{params.beginTotalMinutesDuration} and #{params.endTotalMinutesDuration}</if>
            <if test="params.beginTotalHoursDuration != null and params.beginTotalHoursDuration != '' and params.endTotalHoursDuration != null and params.endTotalHoursDuration != ''"> and total_hours_duration between #{params.beginTotalHoursDuration} and #{params.endTotalHoursDuration}</if>
            <if test="workContent != null  and workContent != ''"> and work_content like concat('%', #{workContent}, '%')</if>
        <!--    <if test="createdBy != null  and createdBy != ''"> and created_by like concat('%', #{createdBy}, '%')</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by like concat('%', #{updatedBy}, '%')</if>-->
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="params.beginCreatedDate != null and params.beginCreatedDate != '' and params.endCreatedDate != null and params.endCreatedDate != ''"> and created_date between #{params.beginCreatedDate} and #{params.endCreatedDate}</if>

            <if test="params.beginUpdatedDate != null and params.beginUpdatedDate != '' and params.endUpdatedDate != null and params.endUpdatedDate != ''"> and updated_date between #{params.beginUpdatedDate} and #{params.endUpdatedDate}</if>
        </where>
        order by created_date desc
    </select>

    <select id="selectWorkTimeRecordByRecordId"  resultMap="WorkTimeRecordResult">
        <include refid="selectWorkTimeRecordVo"/>
        where record_id = #{recordId} and created_by = #{createdBy}
    </select>

    <insert id="insertWorkTimeRecord" parameterType="WorkTimeRecordDTO" useGeneratedKeys="true" keyProperty="recordId">
        insert into work_time_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="belongsProjects != null and belongsProjects != ''">belongs_projects,</if>
            <if test="todayDate != null and todayDate != ''">today_date,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="totalMinutesDuration != null">total_minutes_duration,</if>
            <if test="totalHoursDuration != null">total_hours_duration,</if>
            <if test="workContent != null and workContent != ''">work_content,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="updatedDate != null">updated_date,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="belongsProjects != null and belongsProjects != ''">#{belongsProjects},</if>
            <if test="todayDate != null and todayDate != ''">#{todayDate},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="totalMinutesDuration != null">#{totalMinutesDuration},</if>
            <if test="totalHoursDuration != null">#{totalHoursDuration},</if>
            <if test="workContent != null and workContent != ''">#{workContent},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateWorkTimeRecord" parameterType="WorkTimeRecordDTO">
        update work_time_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="belongsProjects != null and belongsProjects != ''">belongs_projects = #{belongsProjects},</if>
            <if test="todayDate != null and todayDate != ''">today_date = #{todayDate},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="totalMinutesDuration != null">total_minutes_duration = #{totalMinutesDuration},</if>
            <if test="totalHoursDuration != null">total_hours_duration = #{totalHoursDuration},</if>
            <if test="workContent != null and workContent != ''">work_content = #{workContent},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteWorkTimeRecordByRecordId" parameterType="Long">
        delete from work_time_record where record_id = #{recordId}
    </delete>

    <delete id="deleteWorkTimeRecordByRecordIds" parameterType="String">
        delete from work_time_record where record_id in
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>
</mapper>
