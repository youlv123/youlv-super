<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.weixin.mapper.TaskImageRelationMapper">

    <resultMap type="TaskImageRelationDTO" id="TaskImageRelationResult">
        <result property="relationId"    column="relation_id"    />
        <result property="articleTaskName"    column="article_task_name"    />
        <result property="taskId"    column="task_id"    />
        <result property="imageId"    column="image_id"    />
        <result property="templateId"    column="template_id"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createdBy"    column="created_by"    />
        <result property="createdDate"    column="created_date"    />
        <result property="updatedBy"    column="updated_by"    />
        <result property="updatedDate"    column="updated_date"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectTaskImageRelationVo">
        select relation_id, article_task_name, task_id, image_id, template_id, order_num, created_by, created_date, updated_by, updated_date, del_flag from task_image_relation
    </sql>

    <select id="selectTaskImageRelationList" parameterType="TaskImageRelationDTO" resultMap="TaskImageRelationResult">
        <include refid="selectTaskImageRelationVo"/>
        <where>
            <if test="articleTaskName != null  and articleTaskName != ''"> and article_task_name like concat('%', #{articleTaskName}, '%')</if>
            <if test="taskId != null "> and task_id = #{taskId}</if>
            <if test="imageId != null "> and image_id = #{imageId}</if>
            <if test="templateId != null "> and template_id = #{templateId}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
            <if test="createdBy != null  and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="createdDate != null "> and created_date = #{createdDate}</if>
            <if test="updatedBy != null  and updatedBy != ''"> and updated_by = #{updatedBy}</if>
            <if test="updatedDate != null "> and updated_date = #{updatedDate}</if>
        </where>
    </select>

    <select id="selectTaskImageRelationById" parameterType="Long" resultMap="TaskImageRelationResult">
        <include refid="selectTaskImageRelationVo"/>
        where relation_id = #{relationId}
    </select>

    <insert id="insertTaskImageRelation" parameterType="TaskImageRelationDTO" useGeneratedKeys="true" keyProperty="relationId">
        insert into task_image_relation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleTaskName != null">article_task_name,</if>
            <if test="taskId != null">task_id,</if>
            <if test="imageId != null">image_id,</if>
            <if test="templateId != null">template_id,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="createdDate != null">created_date,</if>
            <if test="updatedBy != null">updated_by,</if>
            <if test="updatedDate != null">updated_date,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleTaskName != null">#{articleTaskName},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="imageId != null">#{imageId},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="createdDate != null">#{createdDate},</if>
            <if test="updatedBy != null">#{updatedBy},</if>
            <if test="updatedDate != null">#{updatedDate},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateTaskImageRelation" parameterType="TaskImageRelationDTO">
        update task_image_relation
        <trim prefix="SET" suffixOverrides=",">
            <if test="articleTaskName != null">article_task_name = #{articleTaskName},</if>
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="imageId != null">image_id = #{imageId},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="createdDate != null">created_date = #{createdDate},</if>
            <if test="updatedBy != null">updated_by = #{updatedBy},</if>
            <if test="updatedDate != null">updated_date = #{updatedDate},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where relation_id = #{relationId}
    </update>

    <delete id="deleteTaskImageRelationById" parameterType="Long">
        delete from task_image_relation where relation_id = #{relationId}
    </delete>

    <delete id="deleteTaskImageRelationByIds" parameterType="java.lang.String">
        delete from task_image_relation where relation_id in
        <foreach item="relationId" collection="array" open="(" separator="," close=")">
            #{relationId}
        </foreach>
    </delete>

    <select id="selectTaskImageRelationByTaskId" parameterType="Long" resultMap="TaskImageRelationResult">
        <include refid="selectTaskImageRelationVo"/>
        where task_id = #{taskId} order by order_num asc
    </select>

    <insert id="batchInsertTaskImageRelation" parameterType="TaskImageRelationDTO" useGeneratedKeys="true" keyProperty="relationId">
        insert into task_image_relation
        (article_task_name, task_id, image_id, template_id, order_num)
        values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.articleTaskName},
            #{item.taskId},
            #{item.imageId},
            #{item.templateId},
            #{item.orderNum}
            )
        </foreach>
    </insert>
</mapper>
